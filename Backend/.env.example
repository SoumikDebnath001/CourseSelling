# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database (SHARED with the existing Cricket Academy app) ──
# Point this at the SAME database. This app only READS `users` / `admins`
# and writes exclusively to *_appTwo collections.
MONGODB_URI=mongodb://127.0.0.1:27017/cricket-academy

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Cloudflare R2 (files: thumbnails + resources) ──
# R2 is S3-compatible object storage. Create an API token (R2 → Manage API tokens)
# with Object Read & Write for the bucket below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=courseselling
# Public base URL for the bucket (an r2.dev URL or a custom domain), no trailing
# slash, e.g. https://pub-1234abcd.r2.dev
R2_PUBLIC_URL=

# ── Cloudflare Stream (course videos) ──
# Stream ingests, transcodes and adaptively delivers (HLS) course videos.
CF_ACCOUNT_ID=
# API token with the "Stream:Edit" permission.
CF_STREAM_API_TOKEN=
# Customer subdomain code — the "xyz" in customer-xyz.cloudflarestream.com.
CF_STREAM_CUSTOMER_CODE=

# ── Mail (Nodemailer SMTP) ───────────────────────────────
# REQUIRED for signup OTP / verification emails. With an empty config the server
# refuses to "pretend" an email was sent and returns a clear error instead.
#
# Gmail example (recommended): enable 2-Step Verification on the account, then
# create an "App password" (Google Account → Security → App passwords) and paste
# the 16-character value into MAIL_PASS (NOT your normal Gmail password).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-address@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM="Cricket Academy <your-address@gmail.com>"
