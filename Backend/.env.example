# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── Database (SHARED with the existing Cricket Academy app) ──
# Point this at the SAME database. This app only READS `users` / `admins`
# and writes exclusively to *_appTwo collections.
MONGODB_URI=mongodb://127.0.0.1:27017/cricket-academy

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── AWS S3 + CloudFront (video / thumbnails / resources) ──
# The S3 bucket stores all media (kept PRIVATE). CloudFront is the CDN that
# delivers it fast & cheap to many viewers. See SETUP-AWS.md for a walkthrough.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# CloudFront distribution domain, no protocol, e.g. d1234abcd.cloudfront.net
CLOUDFRONT_DOMAIN=

# ── (Optional, recommended for production) Protected video URLs ──
# Fill these to make course videos stream via short-lived signed URLs so the
# links can't be freely shared/downloaded. Leave blank to serve plain CDN URLs.
CLOUDFRONT_KEY_PAIR_ID=
# Paste the PEM on ONE line, using \n for line breaks. See SETUP-AWS.md.
CLOUDFRONT_PRIVATE_KEY=
SIGNED_URL_TTL_SEC=21600

# ── Mail (Nodemailer SMTP) ───────────────────────────────
# REQUIRED for signup OTP / verification emails. With an empty config the server
# refuses to "pretend" an email was sent and returns a clear error instead.
#
# Gmail example (recommended): enable 2-Step Verification on the account, then
# create an "App password" (Google Account → Security → App passwords) and paste
# the 16-character value into MAIL_PASS (NOT your normal Gmail password).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-address@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM="Cricket Academy <your-address@gmail.com>"
