# ── VPS .env file ─────────────────────────────────────────
# Copy this to ~/cricket-academy/.env on your Hostinger VPS
# and fill in all the values.

# ── Docker ────────────────────────────────────────────────
DOCKER_USERNAME=your_dockerhub_username

# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Client URL (your subdomain) ──────────────────────────
CLIENT_URL=https://YOUR_SUBDOMAIN.yourdomain.com

# ── Cloudflare R2 (PRIVATE bucket) ───────────────────────
# Files are served via short-lived presigned URLs generated by the backend, so the
# bucket can stay private — no public access / r2.dev / custom domain needed.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=courseselling
# Optional/legacy — no longer used for serving. Leave blank.
R2_PUBLIC_URL=

# ── Cloudflare Stream ────────────────────────────────────
CF_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
CF_STREAM_CUSTOMER_CODE=

# ── Mail (SMTP) ──────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-address@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_FROM="Cricket Academy <your-address@gmail.com>"
